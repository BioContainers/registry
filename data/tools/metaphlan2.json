{"description":"Metaphlan is a computational tool for profiling the composition of microbial communities (bacteria, archaea, eukaryotes and viruses) from metagenomic shotgun sequencing data with species level resolution. from version 2.0 metaphlan is also able to identify specific strains (in the not-so-frequent cases in which the sample contains a previously sequenced strains) and to track strains across samples for all species.","home_url":"https://bitbucket.org/biobakery/metaphlan2/get/2.5.0.tar.gz","id":"metaphlan2","license":"","name":"metaphlan2","toolclass":"CommandLineTool","total_pulls":0,"versions":[{"containers":[{"image":"quay.io/biocontainers/metaphlan2:2.2.0--py27_1","type":"docker"},{"type":"singularity","url":"https://depot.galaxyproject.org/singularity/metaphlan2:2.2.0--py27_1"},{"command":"conda install -c bioconda metaphlan2=2.2.0","type":"conda"}],"last_updated":"Fri, 21 Jun 2024 13:34:18 -0000","version":"2.2.0"},{"containers":[{"image":"quay.io/biocontainers/metaphlan2:2.5.0--py27_0","type":"docker"},{"type":"singularity","url":"https://depot.galaxyproject.org/singularity/metaphlan2:2.5.0--py27_0"},{"command":"conda install -c bioconda metaphlan2=2.5.0","type":"conda"},{"image":"quay.io/biocontainers/metaphlan2:2.5.0--py27_2","type":"docker"},{"type":"singularity","url":"https://depot.galaxyproject.org/singularity/metaphlan2:2.5.0--py27_2"}],"last_updated":"Fri, 21 Jun 2024 13:33:52 -0000","version":"2.5.0"},{"containers":[{"image":"quay.io/biocontainers/metaphlan2:2.6.0--py27_1","type":"docker"},{"type":"singularity","url":"https://depot.galaxyproject.org/singularity/metaphlan2:2.6.0--py27_1"},{"command":"conda install -c bioconda metaphlan2=2.6.0","type":"conda"},{"image":"quay.io/biocontainers/metaphlan2:2.6.0--py27_2","type":"docker"},{"type":"singularity","url":"https://depot.galaxyproject.org/singularity/metaphlan2:2.6.0--py27_2"}],"last_updated":"Fri, 21 Jun 2024 13:30:14 -0000","version":"2.6.0"},{"containers":[{"image":"quay.io/biocont